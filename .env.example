# ── Groq (free at console.groq.com) ──────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Server ────────────────────────────────────────────────────
PORT=3001

# ── Mantle deployment ─────────────────────────────────────────
# Your wallet private key (used to sign contract calls)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# RPC — use testnet first, switch to mainnet when ready
MANTLE_RPC=https://rpc.sepolia.mantle.xyz

# ── Contract addresses (filled in after running deploy script) ─
# Run: npx hardhat run scripts/deploy.js --network mantle_testnet
TALENT_REGISTRY_ADDRESS=
DECISION_LOG_ADDRESS=
ESCROW_ADDRESS=
REPUTATION_ADDRESS=
AGENT_REGISTRY_ADDRESS=
